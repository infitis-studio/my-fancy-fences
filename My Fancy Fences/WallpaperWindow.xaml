<Window x:Class="My_Fancy_Fences.WallpaperWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
        Title="Tapety"
        Width="1040"
        Height="680"
        MinWidth="760"
        MinHeight="480"
        WindowStyle="None"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize"
        AllowsTransparency="True"
        Background="Transparent"
        Foreground="#FFE7E2E4"
        FontFamily="Segoe UI Variable Text, Segoe UI"
        FontSize="13"
        Topmost="False">
    <Window.Resources>
        <Style x:Key="FlatButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="#FFE7E2E4"/>
            <Setter Property="Background" Value="#FF29292B"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="12,7"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Border"
                                CornerRadius="6"
                                Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#FF343438"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="MinimalScrollBarStyle" TargetType="ScrollBar">
            <Setter Property="Width" Value="4"/>
            <Setter Property="MinWidth" Value="4"/>
            <Setter Property="MaxWidth" Value="4"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid Background="Transparent">
                            <Track x:Name="PART_Track" IsDirectionReversed="True">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageUpCommand"
                                                  Opacity="0"
                                                  Focusable="False"/>
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border x:Name="ThumbBorder"
                                                        Margin="0,2"
                                                        CornerRadius="2"
                                                        Background="#35FFFFFF"/>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="ThumbBorder"
                                                                Property="Background"
                                                                Value="#66FFFFFF"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageDownCommand"
                                                  Opacity="0"
                                                  Focusable="False"/>
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ScrollBar"
               BasedOn="{StaticResource MinimalScrollBarStyle}"/>

        <Style x:Key="RoundSearchButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="28"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Background" Value="#FF2D2D30"/>
            <Setter Property="Foreground" Value="#FFE7E2E4"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <Ellipse x:Name="Circle"
                                     Fill="{TemplateBinding Background}"/>
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Circle" Property="Fill" Value="#FF3A3A3F"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Circle" Property="Fill" Value="#FF46464B"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SortButtonStyle"
               TargetType="RadioButton">
            <Setter Property="Foreground" Value="#FFA9A2A5"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Border"
                                CornerRadius="6"
                                Background="Transparent">
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#FF29292D"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#FF36363B"/>
                                <Setter Property="Foreground" Value="#FFF1EDEE"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="FilterCheckBoxStyle" TargetType="CheckBox">
            <Setter Property="Foreground" Value="#FFE7E2E4"/>
            <Setter Property="Margin" Value="0,5"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <StackPanel Orientation="Horizontal">
                            <Border x:Name="Box"
                                    Width="16"
                                    Height="16"
                                    CornerRadius="4"
                                    Background="#FF242427"
                                    BorderBrush="#FF3E3E43"
                                    BorderThickness="1">
                                <Path x:Name="Mark"
                                      Width="8"
                                      Height="6"
                                      Data="M 0 2.5 L 3 5.5 L 8 0"
                                      Stroke="White"
                                      StrokeThickness="1.7"
                                      Visibility="Collapsed"/>
                            </Border>
                            <ContentPresenter Margin="8,0,0,0"
                                              VerticalAlignment="Center"
                                              TextElement.Foreground="#FFE7E2E4"/>
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Box" Property="Background" Value="#FF46464C"/>
                                <Setter TargetName="Box" Property="BorderBrush" Value="#FF58585F"/>
                                <Setter TargetName="Mark" Property="Visibility" Value="Visible"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="FilterToggleStyle" TargetType="ToggleButton">
            <Setter Property="Height" Value="31"/>
            <Setter Property="Margin" Value="0,4"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="Foreground" Value="#FFC7C0C3"/>
            <Setter Property="Background" Value="#FF252529"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="ToggleBorder"
                                CornerRadius="5"
                                Background="{TemplateBinding Background}">
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ToggleBorder" Property="Background" Value="#FF303034"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="ToggleBorder" Property="Background" Value="#FF3A3A3F"/>
                                <Setter Property="Foreground" Value="#FFF1EDEE"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Height" Value="31"/>
            <Setter Property="Margin" Value="0,5,0,10"/>
            <Setter Property="Background" Value="#FF252529"/>
            <Setter Property="Foreground" Value="#FFE7E2E4"/>
            <Setter Property="BorderBrush" Value="#FF3B3B40"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton IsChecked="{Binding IsDropDownOpen,
                                                              RelativeSource={RelativeSource TemplatedParent},
                                                              Mode=TwoWay}"
                                          Focusable="False">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border Background="#FF252529"
                                                BorderBrush="#FF3B3B40"
                                                BorderThickness="1"
                                                CornerRadius="5">
                                            <Grid Margin="9,0,8,0">
                                                <ContentPresenter Content="{Binding SelectedItem.Content,
                                                                                    RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                                                  VerticalAlignment="Center"
                                                                  TextElement.Foreground="#FFE7E2E4"/>
                                                <iconPacks:PackIconLucide Kind="ChevronDown"
                                                                          Width="14"
                                                                          Height="14"
                                                                          Foreground="#FFA9A2A5"
                                                                          HorizontalAlignment="Right"
                                                                          VerticalAlignment="Center"/>
                                            </Grid>
                                        </Border>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <Popup IsOpen="{TemplateBinding IsDropDownOpen}"
                                   Placement="Bottom"
                                   AllowsTransparency="True"
                                   Focusable="False">
                                <Border MinWidth="{Binding ActualWidth,
                                                           RelativeSource={RelativeSource TemplatedParent}}"
                                        Margin="0,3,0,0"
                                        Padding="4"
                                        CornerRadius="5"
                                        Background="#FF252529"
                                        BorderBrush="#FF3B3B40"
                                        BorderThickness="1">
                                    <ScrollViewer>
                                        <ItemsPresenter/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="ComboBoxItem">
                        <Setter Property="Height" Value="30"/>
                        <Setter Property="Padding" Value="9,0"/>
                        <Setter Property="Foreground" Value="#FFE7E2E4"/>
                        <Setter Property="Background" Value="#FF252529"/>
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ComboBoxItem">
                                    <Border x:Name="ItemBorder"
                                            CornerRadius="4"
                                            Background="{TemplateBinding Background}">
                                        <ContentPresenter Margin="{TemplateBinding Padding}"
                                                          VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="ItemBorder" Property="Background" Value="#FF343438"/>
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="ItemBorder" Property="Background" Value="#FF44444A"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="WallpaperCardStyle" TargetType="Button">
            <Setter Property="Margin" Value="6"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Width" Value="238"/>
            <Setter Property="Height" Value="158"/>
            <Setter Property="Background" Value="#FF1D1D20"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Card"
                                CornerRadius="8"
                                Background="{TemplateBinding Background}"
                                ClipToBounds="True">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Card" Property="Opacity" Value=".86"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="WindowCaptionButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="36"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="#FFE7E2E4"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                CornerRadius="7"
                                Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#22FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="WindowCloseButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource WindowCaptionButtonStyle}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                CornerRadius="7"
                                Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#FFE81123"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border x:Name="OuterWindowBorder"
            BorderBrush="#FF3A3438"
            BorderThickness="1"
            CornerRadius="13"
            ClipToBounds="True">
        <Border.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#FF191719" Offset="0"/>
                <GradientStop Color="#FF141416" Offset=".5"/>
                <GradientStop Color="#FF111113" Offset="1"/>
            </LinearGradientBrush>
        </Border.Background>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="46"/>
                <RowDefinition Height="58"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border x:Name="TitleBarBorder"
                    CornerRadius="12,12,0,0"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#FF2B2025" Offset="0"/>
                        <GradientStop Color="#FF1D1C20" Offset=".45"/>
                        <GradientStop Color="#FF171719" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <Grid Margin="16,0,7,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <iconPacks:PackIconLucide Kind="Wallpaper"
                                                  Width="18"
                                                  Height="18"
                                                  Margin="0,0,10,0"
                                                  Foreground="#FFC9C2C5"/>
                        <TextBlock Text="Tapety z Wallhaven"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center">
                        <Button Style="{StaticResource WindowCaptionButtonStyle}"
                                Width="34"
                                Height="32"
                                Background="Transparent"
                                BorderThickness="0"
                                Foreground="#FFE7E2E4"
                                Cursor="Hand"
                                ToolTip="Minimalizuj"
                                Click="MinimizeButton_Click">
                            <iconPacks:PackIconLucide Kind="Minus" Width="16" Height="16"/>
                        </Button>
                        <Button Style="{StaticResource WindowCaptionButtonStyle}"
                                Width="34"
                                Height="32"
                                Background="Transparent"
                                BorderThickness="0"
                                Foreground="#FFE7E2E4"
                                Cursor="Hand"
                                ToolTip="Pełny ekran"
                                Click="MaximizeButton_Click">
                            <iconPacks:PackIconLucide x:Name="MaximizeIcon"
                                                      Kind="Square"
                                                      Width="14"
                                                      Height="14"/>
                        </Button>
                        <Button Content="×"
                                Style="{StaticResource WindowCloseButtonStyle}"
                                Width="34"
                                Height="32"
                                Background="Transparent"
                                BorderThickness="0"
                                Foreground="#FFE7E2E4"
                                FontSize="20"
                                Cursor="Hand"
                                Click="CloseButton_Click"/>
                    </StackPanel>
                </Grid>
            </Border>

            <Border Grid.Row="1"
                    BorderBrush="#FF302C30"
                    BorderThickness="0,0,0,1">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#CC2B2025" Offset="0"/>
                        <GradientStop Color="#661D1D20" Offset=".55"/>
                        <GradientStop Color="#00141416" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <Grid Margin="15,9" Background="Transparent">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="380"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Grid Background="Transparent">
                        <Border CornerRadius="7"
                                Background="#FF222225"
                                BorderBrush="#FF37373B"
                                BorderThickness="1"/>
                        <Grid Margin="10,0,5,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <iconPacks:PackIconLucide Kind="Search"
                                                      Width="16"
                                                      Height="16"
                                                      Margin="0,0,8,0"
                                                      Foreground="#FFA9A2A5"
                                                      VerticalAlignment="Center"/>
                            <TextBox x:Name="SearchTextBox"
                                     Grid.Column="1"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     Foreground="#FFE7E2E4"
                                     CaretBrush="#FFE7E2E4"
                                     VerticalContentAlignment="Center"
                                     KeyDown="SearchTextBox_KeyDown"/>
                            <Button Grid.Column="2"
                                    Style="{StaticResource RoundSearchButtonStyle}"
                                    Margin="4,0,0,0"
                                    Click="AddTagButton_Click">
                                <iconPacks:PackIconLucide Kind="Plus" Width="14" Height="14"/>
                            </Button>
                        </Grid>
                    </Grid>

                    <ItemsControl x:Name="TagsItemsControl"
                                  Grid.Column="1"
                                  Margin="12,0"
                                  VerticalAlignment="Center">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="3,2"
                                        Padding="8,4"
                                        CornerRadius="5"
                                        Background="{Binding Background}">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding Text}"
                                                   Foreground="#FFE7E2E4"
                                                   FontSize="11"/>
                                        <Button Tag="{Binding Text}"
                                                Content="×"
                                                Margin="6,-3,-4,-3"
                                                Padding="3,0"
                                                Background="Transparent"
                                                BorderThickness="0"
                                                Foreground="#FFE7E2E4"
                                                Cursor="Hand"
                                                Click="RemoveTagButton_Click"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <StackPanel Grid.Column="2"
                                Orientation="Horizontal"
                                VerticalAlignment="Center">
                        <RadioButton x:Name="LatestSortButton"
                                     GroupName="Sorting"
                                     Content="Latest"
                                     Tag="date_added"
                                     IsChecked="True"
                                     Style="{StaticResource SortButtonStyle}"
                                     Checked="SortButton_Checked"/>
                        <RadioButton GroupName="Sorting"
                                     Content="Hot"
                                     Tag="hot"
                                     Margin="4,0"
                                     Style="{StaticResource SortButtonStyle}"
                                     Checked="SortButton_Checked"/>
                        <RadioButton GroupName="Sorting"
                                     Content="Toplist"
                                     Tag="toplist"
                                     Style="{StaticResource SortButtonStyle}"
                                     Checked="SortButton_Checked"/>
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="190"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border x:Name="SidebarBorder"
                        BorderBrush="#FF302C30"
                        CornerRadius="0,0,0,12"
                        BorderThickness="0,0,1,0">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#FF2B2025" Offset="0"/>
                            <GradientStop Color="#FF211C20" Offset=".45"/>
                            <GradientStop Color="#FF181719" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="17,15">
                            <TextBlock Text="Kategorie"
                                       Foreground="#FF9D969A"
                                       FontSize="10"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,5"/>
                            <ToggleButton x:Name="GeneralCheckBox"
                                          Content="General"
                                          IsChecked="True"
                                          Style="{StaticResource FilterToggleStyle}"
                                          Checked="Filter_Changed"
                                          Unchecked="Filter_Changed"/>
                            <ToggleButton x:Name="AnimeCheckBox"
                                          Content="Anime"
                                          IsChecked="True"
                                          Style="{StaticResource FilterToggleStyle}"
                                          Checked="Filter_Changed"
                                          Unchecked="Filter_Changed"/>
                            <ToggleButton x:Name="PeopleCheckBox"
                                          Content="People"
                                          IsChecked="True"
                                          Style="{StaticResource FilterToggleStyle}"
                                          Checked="Filter_Changed"
                                          Unchecked="Filter_Changed"/>

                            <Border Height="1" Margin="0,12" Background="#FF332E32"/>

                            <TextBlock Text="Czystość"
                                       Foreground="#FF9D969A"
                                       FontSize="10"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,5"/>
                            <ToggleButton x:Name="SfwCheckBox"
                                          Content="SFW"
                                          IsChecked="True"
                                          Style="{StaticResource FilterToggleStyle}"
                                          Checked="Filter_Changed"
                                          Unchecked="Filter_Changed"/>
                            <ToggleButton x:Name="SketchyCheckBox"
                                          Content="Sketchy"
                                          Style="{StaticResource FilterToggleStyle}"
                                          Checked="Filter_Changed"
                                          Unchecked="Filter_Changed"/>

                            <Border Height="1" Margin="0,12" Background="#FF332E32"/>

                            <TextBlock Text="Resolution"
                                       Foreground="#FF9D969A"
                                       FontSize="10"
                                       FontWeight="SemiBold"/>
                            <ComboBox x:Name="ResolutionComboBox"
                                      SelectionChanged="FilterComboBox_SelectionChanged">
                                <ComboBoxItem Content="Any" Tag=""/>
                                <ComboBoxItem Content="1920×1080" Tag="1920x1080"/>
                                <ComboBoxItem Content="2560×1440" Tag="2560x1440"/>
                                <ComboBoxItem Content="3840×2160" Tag="3840x2160"/>
                                <ComboBoxItem Content="5120×2880" Tag="5120x2880"/>
                            </ComboBox>

                            <TextBlock Text="Ratio"
                                       Foreground="#FF9D969A"
                                       FontSize="10"
                                       FontWeight="SemiBold"/>
                            <ComboBox x:Name="RatioComboBox"
                                      SelectionChanged="FilterComboBox_SelectionChanged">
                                <ComboBoxItem Content="Any" Tag=""/>
                                <ComboBoxItem Content="16:9" Tag="16x9"/>
                                <ComboBoxItem Content="16:10" Tag="16x10"/>
                                <ComboBoxItem Content="21:9" Tag="21x9"/>
                                <ComboBoxItem Content="4:3" Tag="4x3"/>
                                <ComboBoxItem Content="Portrait" Tag="portrait"/>
                            </ComboBox>

                            <TextBlock Text="Color"
                                       Foreground="#FF9D969A"
                                       FontSize="10"
                                       FontWeight="SemiBold"/>
                            <ComboBox x:Name="ColorComboBox"
                                      SelectionChanged="FilterComboBox_SelectionChanged">
                                <ComboBoxItem Content="Any" Tag=""/>
                                <ComboBoxItem Content="Red" Tag="cc0000"/>
                                <ComboBoxItem Content="Orange" Tag="ea4c00"/>
                                <ComboBoxItem Content="Yellow" Tag="e7d600"/>
                                <ComboBoxItem Content="Green" Tag="00aa55"/>
                                <ComboBoxItem Content="Blue" Tag="0066cc"/>
                                <ComboBoxItem Content="Purple" Tag="9900cc"/>
                                <ComboBoxItem Content="Black" Tag="000000"/>
                                <ComboBoxItem Content="White" Tag="ffffff"/>
                            </ComboBox>
                        </StackPanel>
                    </ScrollViewer>
                </Border>

                <Grid Grid.Column="1">
                    <ScrollViewer x:Name="WallpapersScrollViewer"
                                  Margin="8"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled"
                                  ScrollChanged="WallpapersScrollViewer_ScrollChanged">
                        <ItemsControl x:Name="WallpapersItemsControl">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel HorizontalAlignment="Center"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Style="{StaticResource WallpaperCardStyle}"
                                            Tag="{Binding}"
                                            ToolTip="{Binding Resolution}"
                                            Click="WallpaperButton_Click">
                                        <Grid>
                                            <Image Source="{Binding ThumbnailImage}"
                                                   Stretch="UniformToFill"
                                                   RenderOptions.BitmapScalingMode="HighQuality"/>
                                            <Border VerticalAlignment="Bottom"
                                                    Padding="9,6"
                                                    Background="#A0000000">
                                                <TextBlock Text="{Binding Resolution}"
                                                           FontSize="10"
                                                           Foreground="White"/>
                                            </Border>
                                        </Grid>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <Border x:Name="LoadingOverlay"
                            Width="112"
                            Height="112"
                            CornerRadius="12"
                            Background="#E622262E"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                        <StackPanel HorizontalAlignment="Center"
                                    VerticalAlignment="Center">
                            <Grid Width="34" Height="34" HorizontalAlignment="Center">
                                <Ellipse Stroke="#3AFFFFFF"
                                         StrokeThickness="3"/>
                                <Ellipse Stroke="#FFB8A7AE"
                                         StrokeThickness="3"
                                         StrokeDashArray="2,6"
                                         StrokeStartLineCap="Round">
                                    <Ellipse.RenderTransform>
                                        <RotateTransform x:Name="LoadingRotateTransform"
                                                         CenterX="17"
                                                         CenterY="17"/>
                                    </Ellipse.RenderTransform>
                                </Ellipse>
                            </Grid>
                            <TextBlock Text="Ładowanie"
                                       Margin="0,12,0,0"
                                       Foreground="#FFD8D1D4"
                                       FontSize="11"
                                       TextAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <StackPanel x:Name="StatusPanel"
                                Visibility="Collapsed"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center">
                        <TextBlock x:Name="StatusText"
                                   Foreground="#FFC9C2C5"
                                   FontSize="13"
                                   TextAlignment="Center"/>
                        <Button x:Name="RetryButton"
                                Content="Spróbuj ponownie"
                                Style="{StaticResource FlatButtonStyle}"
                                Margin="0,14,0,0"
                                Visibility="Collapsed"
                                Click="RefreshButton_Click"/>
                    </StackPanel>
                </Grid>
            </Grid>
            <Border x:Name="ResizeGrip"
                    Width="26"
                    Height="26"
                    Grid.RowSpan="3"
                    Panel.ZIndex="20"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Bottom"
                    Background="Transparent"
                    Cursor="SizeNWSE"
                    MouseLeftButtonDown="ResizeGrip_MouseLeftButtonDown"
                    MouseLeftButtonUp="ResizeGrip_MouseLeftButtonUp"
                    MouseMove="ResizeGrip_MouseMove">
                <Canvas Width="16"
                        Height="16"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Bottom"
                        Margin="0,0,5,5"
                        Opacity=".48">
                    <Path Data="M 15 6 L 6 15"
                          Stroke="White"
                          StrokeThickness="1.4"
                          StrokeStartLineCap="Round"
                          StrokeEndLineCap="Round"/>
                    <Path Data="M 15 11 L 11 15"
                          Stroke="White"
                          StrokeThickness="1.4"
                          StrokeStartLineCap="Round"
                          StrokeEndLineCap="Round"/>
                </Canvas>
            </Border>
        </Grid>
    </Border>
</Window>
