<Window x:Class="My_Fancy_Fences.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
        xmlns:local="clr-namespace:My_Fancy_Fences"
        mc:Ignorable="d"
        Title="My Fancy Fences"
        Width="430"
        Height="292"
        MinWidth="310"
        MinHeight="70"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="CanResize"
        AllowDrop="True"
        DragEnter="Panel_DragEnter"
        DragOver="Panel_DragOver"
        DragLeave="Panel_DragLeave"
        Drop="Panel_Drop"
        ShowInTaskbar="False"
        ShowActivated="False"
        Topmost="False">
    <Window.Resources>
        <SolidColorBrush x:Key="TextPrimary" Color="#FFF7F9FC"/>
        <SolidColorBrush x:Key="TextMuted" Color="#B9D9E0EA"/>

        <Style x:Key="IconButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="28"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Foreground" Value="{StaticResource TextMuted}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                CornerRadius="7"
                                Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#24FFFFFF"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#38FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TileStyle" TargetType="Button">
            <Setter Property="Width" Value="{DynamicResource DesktopTileWidth}"/>
            <Setter Property="Height" Value="{DynamicResource DesktopTileHeight}"/>
            <Setter Property="Margin" Value="{DynamicResource DesktopTileMargin}"/>
            <Setter Property="Padding" Value="4"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="TileBorder"
                                CornerRadius="9"
                                Background="{TemplateBinding Background}">
                            <ContentPresenter/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="MinimalScrollBarStyle" TargetType="ScrollBar">
            <Setter Property="Width" Value="4"/>
            <Setter Property="MinWidth" Value="4"/>
            <Setter Property="MaxWidth" Value="4"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#42FFFFFF"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid Background="Transparent">
                            <Track x:Name="PART_Track" IsDirectionReversed="True">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageUpCommand"
                                                  Opacity="0"
                                                  Focusable="False"/>
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border x:Name="ThumbBorder"
                                                        Margin="0,2"
                                                        CornerRadius="2"
                                                        Background="#35FFFFFF"/>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="ThumbBorder"
                                                                Property="Background"
                                                                Value="#66FFFFFF"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageDownCommand"
                                                  Opacity="0"
                                                  Focusable="False"/>
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border x:Name="FenceBorder"
            Margin="9"
            CornerRadius="11"
            BorderThickness="0"
            Background="#940B0E12">

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition x:Name="HeaderRow" Height="48"/>
                <RowDefinition x:Name="ContentRow" Height="*"/>
            </Grid.RowDefinitions>

            <Border x:Name="DragSurface"
                    Grid.Row="0"
                    CornerRadius="10,10,0,0"
                    Background="Transparent"
                    MouseLeftButtonDown="DragSurface_MouseLeftButtonDown"
                    MouseLeftButtonUp="DragSurface_MouseLeftButtonUp"
                    MouseMove="DragSurface_MouseMove">
                <Grid Margin="14,0">
                    <StackPanel x:Name="HeaderContent"
                                Orientation="Horizontal"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center">
                        <iconPacks:PackIconLucide x:Name="HeaderIcon"
                                   Kind="Settings"
                                   Width="17"
                                   Height="17"
                                   Margin="0,0,10,0"
                                   Foreground="{StaticResource TextMuted}"
                                   VerticalAlignment="Center"
                                   IsHitTestVisible="False"/>
                        <local:LetterSpacedTextBlock x:Name="TitleText"
                                                     Text="Mój pulpit"
                                                     FontSize="16"
                                                     FontWeight="SemiBold"
                                                     Foreground="{DynamicResource HeaderTextPrimary}"
                                                     LetterSpacing="{DynamicResource HeaderLetterSpacing}"
                                                     VerticalAlignment="Center"/>
                    </StackPanel>
                </Grid>
            </Border>

            <ScrollViewer x:Name="ItemsScrollViewer"
                          Grid.Row="1"
                          Margin="9,5,7,10"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <ScrollViewer.Resources>
                    <Style TargetType="ScrollBar"
                           BasedOn="{StaticResource MinimalScrollBarStyle}"/>
                </ScrollViewer.Resources>
                <ItemsControl x:Name="DesktopItemsControl">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button Style="{StaticResource TileStyle}"
                                    ToolTip="{Binding Path}"
                                    Tag="{Binding Path}"
                                    PreviewMouseRightButtonUp="DesktopItem_MouseRightButtonUp"
                                    PreviewMouseLeftButtonDown="DesktopItem_MouseLeftButtonDown">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="{DynamicResource DesktopIconRowHeight}"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>
                                    <Image Height="{DynamicResource DesktopIconSize}"
                                           Width="{DynamicResource DesktopIconSize}"
                                           Source="{Binding Icon}"
                                           Stretch="Uniform"
                                           RenderOptions.BitmapScalingMode="HighQuality"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                                    <local:LetterSpacedTextBlock Grid.Row="1"
                                                                 Text="{Binding Name}"
                                                                 Margin="{DynamicResource DesktopLabelMargin}"
                                                                 FontFamily="{DynamicResource IconFontFamily}"
                                                                 FontSize="{DynamicResource DesktopLabelFontSize}"
                                                                 FontWeight="{DynamicResource IconFontWeight}"
                                                                 Foreground="{DynamicResource IconTextPrimary}"
                                                                 LetterSpacing="{DynamicResource IconLetterSpacing}"
                                                                 TextAlignment="Center"
                                                                 MaxLines="2"
                                                                 MaxHeight="{DynamicResource DesktopLabelHeight}"
                                                                 HorizontalAlignment="Stretch"/>
                                </Grid>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <Border Grid.Row="1"
                    Width="18"
                    Height="18"
                    Margin="0,0,3,3"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Bottom"
                    Background="Transparent"
                    Cursor="SizeNWSE"
                    MouseLeftButtonDown="ResizeArea_MouseLeftButtonDown"
                    MouseLeftButtonUp="ResizeArea_MouseLeftButtonUp"
                    MouseMove="ResizeArea_MouseMove"/>

            <Popup x:Name="ItemActionsPopup"
                   Placement="MousePoint"
                   AllowsTransparency="True"
                   StaysOpen="False"
                   Closed="ItemActionsPopup_Closed"
                   PopupAnimation="Fade">
                <Border Width="166"
                        Padding="5"
                        CornerRadius="10"
                        Background="#F51B1E24"
                        BorderBrush="#2EFFFFFF"
                        BorderThickness="1">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="18"
                                          ShadowDepth="4"
                                          Direction="270"
                                          Opacity="0.38"
                                          Color="#FF000000"/>
                    </Border.Effect>
                    <Button Height="38"
                            Padding="11,0"
                            Foreground="#FFFCA5A5"
                            Background="Transparent"
                            BorderThickness="0"
                            Cursor="Hand"
                            HorizontalContentAlignment="Stretch"
                            Click="DeleteDesktopItemMenuItem_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="ActionBackground"
                                        Padding="{TemplateBinding Padding}"
                                        CornerRadius="7"
                                        Background="{TemplateBinding Background}">
                                    <ContentPresenter HorizontalAlignment="Stretch"
                                                      VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="ActionBackground" Property="Background" Value="#2BEF4444"/>
                                    </Trigger>
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter TargetName="ActionBackground" Property="Background" Value="#46EF4444"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                        <StackPanel Orientation="Horizontal">
                            <iconPacks:PackIconLucide Kind="Trash2"
                                                       Width="16"
                                                       Height="16"
                                                       Margin="0,0,10,0"
                                                       Foreground="#FFF87171"/>
                            <TextBlock Text="Usuń ikonę"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </Border>
            </Popup>

        </Grid>
    </Border>
</Window>
