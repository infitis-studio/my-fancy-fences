<Window x:Class="My_Fancy_Fences.SupportBannerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="118"
        Height="134"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent"
        ShowActivated="False"
        ShowInTaskbar="False"
        Focusable="False"
        Topmost="False">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="63"/>
            <RowDefinition Height="8"/>
            <RowDefinition Height="63"/>
        </Grid.RowDefinitions>

        <Image Grid.Row="0"
               Width="118"
               HorizontalAlignment="Right"
               Source="/Assets/ko-fi-support.png"
               Stretch="UniformToFill"
               RenderOptions.BitmapScalingMode="HighQuality"
               SnapsToDevicePixels="False"
               UseLayoutRounding="False"
               Cursor="Hand"
               MouseLeftButtonUp="SupportBanner_MouseLeftButtonUp"/>

        <Border Grid.Row="2"
                Background="#FF24252A"
                BorderBrush="#FF24252A"
                BorderThickness="1"
                CornerRadius="8,0,0,8">
            <TextBlock Text="Ostatnia aktualizacja&#x0a;z dnia: 3.06.2026"
                       Margin="9,4,7,4"
                       Foreground="#FFE7E2E4"
                       FontFamily="Segoe UI Variable Text, Segoe UI"
                       FontSize="9.5"
                       FontWeight="SemiBold"
                       TextAlignment="Center"
                       VerticalAlignment="Center"/>
        </Border>
    </Grid>
</Window>
