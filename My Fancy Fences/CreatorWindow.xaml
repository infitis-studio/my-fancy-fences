<Window x:Class="My_Fancy_Fences.CreatorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
        Title="Kreator"
        Width="360"
        Height="160"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        ShowActivated="False">
    <Window.Resources>
        <Style x:Key="CreatorTileStyle" TargetType="Button">
            <Setter Property="Width" Value="78"/>
            <Setter Property="Height" Value="88"/>
            <Setter Property="Margin" Value="3"/>
            <Setter Property="Foreground" Value="#FFF7F9FC"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid Width="78"
                              Height="88"
                              Background="Transparent">
                            <ContentPresenter HorizontalAlignment="Stretch"
                                              VerticalAlignment="Stretch"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="CreatorIconGlowStyle" TargetType="Border">
            <Setter Property="Width" Value="48"/>
            <Setter Property="Height" Value="48"/>
            <Setter Property="CornerRadius" Value="24"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#7EBEB4"
                                      BlurRadius="0"
                                      ShadowDepth="0"
                                      Opacity="0"/>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=Button}}"
                             Value="True">
                    <Setter Property="Background" Value="#10FFFFFF"/>
                    <Setter Property="Effect">
                        <Setter.Value>
                            <DropShadowEffect Color="#7ED8CC"
                                              BlurRadius="14"
                                              ShadowDepth="0"
                                              Opacity=".4"/>
                        </Setter.Value>
                    </Setter>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Border x:Name="FenceBorder"
            Margin="9"
            CornerRadius="11"
            Background="#940B0E12">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition x:Name="HeaderRow" Height="48"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border x:Name="DragSurface"
                    Background="Transparent"
                    MouseLeftButtonDown="DragSurface_MouseLeftButtonDown"
                    MouseLeftButtonUp="DragSurface_MouseLeftButtonUp"
                    MouseMove="DragSurface_MouseMove">
                <StackPanel x:Name="HeaderContent"
                            Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                    <iconPacks:PackIconLucide Kind="LayoutGrid"
                                             Width="17"
                                             Height="17"
                                             Margin="0,0,10,0"
                                             Foreground="#B9D9E0EA"
                                             VerticalAlignment="Center"/>
                    <TextBlock Text="Kreator"
                               FontSize="16"
                               FontWeight="SemiBold"
                               Foreground="#FFF7F9FC"
                               VerticalAlignment="Center">
                        <TextBlock.RenderTransform>
                            <TranslateTransform Y="-2"/>
                        </TextBlock.RenderTransform>
                    </TextBlock>
                </StackPanel>
            </Border>

            <UniformGrid Grid.Row="1"
                         Rows="1"
                         Columns="4"
                         Margin="12,0,12,12"
                         HorizontalAlignment="Center">
                <Grid>
                <Button Style="{StaticResource CreatorTileStyle}"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Click="NewPanelButton_Click">
                    <StackPanel VerticalAlignment="Center">
                        <Border Style="{StaticResource CreatorIconGlowStyle}">
                            <iconPacks:PackIconLucide Kind="Plus"
                                                     Width="{DynamicResource CreatorIconSize}"
                                                     Height="{DynamicResource CreatorIconSize}"
                                                     Opacity=".72"
                                                     Foreground="White"
                                                     HorizontalAlignment="Center"
                                                     VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="Nowy panel" Margin="0,8,0,0" FontSize="11" TextAlignment="Center"/>
                    </StackPanel>
                </Button>
                </Grid>
                <Grid>
                <Button Style="{StaticResource CreatorTileStyle}"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Click="WallpaperButton_Click">
                    <StackPanel VerticalAlignment="Center">
                        <Border Style="{StaticResource CreatorIconGlowStyle}">
                            <iconPacks:PackIconLucide Kind="Wallpaper"
                                                     Width="{DynamicResource CreatorIconSize}"
                                                     Height="{DynamicResource CreatorIconSize}"
                                                     Opacity=".72"
                                                     Foreground="White"
                                                     HorizontalAlignment="Center"
                                                     VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="Tapeta" Margin="0,8,0,0" FontSize="11" TextAlignment="Center"/>
                    </StackPanel>
                </Button>
                </Grid>
                <Grid>
                <Button Style="{StaticResource CreatorTileStyle}"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Click="AppearanceButton_Click">
                    <StackPanel VerticalAlignment="Center">
                        <Border Style="{StaticResource CreatorIconGlowStyle}">
                            <iconPacks:PackIconLucide Kind="Palette"
                                                     Width="{DynamicResource CreatorIconSize}"
                                                     Height="{DynamicResource CreatorIconSize}"
                                                     Opacity=".72"
                                                     Foreground="White"
                                                     HorizontalAlignment="Center"
                                                     VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="Wygląd" Margin="0,8,0,0" FontSize="11" TextAlignment="Center"/>
                    </StackPanel>
                </Button>
                </Grid>
                <Grid>
                <Button Style="{StaticResource CreatorTileStyle}"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Click="SettingsButton_Click">
                    <StackPanel VerticalAlignment="Center">
                        <Border Style="{StaticResource CreatorIconGlowStyle}">
                            <iconPacks:PackIconLucide Kind="Settings"
                                                     Width="{DynamicResource CreatorIconSize}"
                                                     Height="{DynamicResource CreatorIconSize}"
                                                     Opacity=".72"
                                                     Foreground="White"
                                                     HorizontalAlignment="Center"
                                                     VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="Ustawienia" Margin="0,8,0,0" FontSize="11" TextAlignment="Center"/>
                    </StackPanel>
                </Button>
                </Grid>
            </UniformGrid>

        </Grid>
    </Border>
</Window>
