<Window x:Class="My_Fancy_Fences.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
        Title="Ustawienia panelu"
        Width="720"
        Height="520"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        Topmost="False"
        ShowActivated="True"
        AllowsTransparency="True"
        Background="Transparent"
        Foreground="#FFE7E2E4"
        FontFamily="Segoe UI Variable Text, Segoe UI"
        FontSize="13">
    <Window.Resources>
        <Style TargetType="TextBox">
            <Setter Property="Height" Value="36"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="Margin" Value="0,5,0,14"/>
            <Setter Property="Foreground" Value="#FFE7E2E4"/>
            <Setter Property="Background" Value="#FF242427"/>
            <Setter Property="BorderBrush" Value="#FF3B3B40"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CaretBrush" Value="White"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style x:Key="ModernCheckBoxStyle" TargetType="CheckBox">
            <Setter Property="Foreground" Value="#FFE7E2E4"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <StackPanel Orientation="Horizontal">
                            <Border x:Name="CheckBorder"
                                    Width="20"
                                    Height="20"
                                    CornerRadius="5"
                                    Background="#FF242427"
                                    BorderBrush="#FF3E3E43"
                                    BorderThickness="1">
                                <Path x:Name="CheckMark"
                                      Width="10"
                                      Height="7"
                                      Data="M 0 3 L 3.5 6.5 L 10 0"
                                      Stroke="White"
                                      StrokeThickness="2"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round"
                                      Visibility="Collapsed"/>
                            </Border>
                            <ContentPresenter Margin="10,0,0,0"
                                              VerticalAlignment="Center"/>
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="CheckBorder" Property="BorderBrush" Value="#FF65656C"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="CheckBorder" Property="Background" Value="#FF46464C"/>
                                <Setter TargetName="CheckBorder" Property="BorderBrush" Value="#FF58585F"/>
                                <Setter TargetName="CheckMark" Property="Visibility" Value="Visible"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Height" Value="44"/>
            <Setter Property="Margin" Value="0,5,0,14"/>
            <Setter Property="Foreground" Value="#FFE7E2E4"/>
            <Setter Property="Background" Value="#FF242427"/>
            <Setter Property="BorderBrush" Value="#FF3B3B40"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="MaxDropDownHeight" Value="230"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="DropDownToggle"
                                          Focusable="False"
                                          IsChecked="{Binding IsDropDownOpen,
                                                              RelativeSource={RelativeSource TemplatedParent},
                                                              Mode=TwoWay}"
                                          Background="#FF242427"
                                          BorderBrush="#FF3B3B40"
                                          BorderThickness="1">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border x:Name="ClosedBorder"
                                                Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                CornerRadius="4">
                                            <Grid Margin="12,0,10,0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="22"/>
                                                </Grid.ColumnDefinitions>
                                                <iconPacks:PackIconLucide Grid.Column="0"
                                                                         Kind="{Binding SelectedItem,
                                                                                        RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                                                         Width="21"
                                                                         Height="21"
                                                                         Foreground="White"
                                                                         HorizontalAlignment="Left"
                                                                         VerticalAlignment="Center"/>
                                                <Path Grid.Column="1"
                                                      Width="8"
                                                      Height="5"
                                                      Data="M 0 0 L 4 4 L 8 0"
                                                      Stroke="#FFBFC6D0"
                                                      StrokeThickness="1.5"
                                                      HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"/>
                                            </Grid>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="ClosedBorder"
                                                        Property="Background"
                                                        Value="#FF343438"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>

                            <Popup x:Name="PART_Popup"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   Placement="Bottom"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   PopupAnimation="Fade">
                                <Border Margin="0,3,0,0"
                                        Padding="5"
                                        MinWidth="{Binding ActualWidth,
                                                           RelativeSource={RelativeSource TemplatedParent}}"
                                        MaxHeight="{TemplateBinding MaxDropDownHeight}"
                                        Background="#FF242427"
                                        BorderBrush="#FF3B3B40"
                                        BorderThickness="1"
                                        CornerRadius="5">
                                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                                        <ItemsPresenter/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="#FFE7E2E4"/>
            <Setter Property="Background" Value="#FF242427"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="ItemBorder"
                                Background="{TemplateBinding Background}"
                                CornerRadius="5"
                                Margin="2">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#FF343438"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#FF44444A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="Button">
            <Setter Property="MinWidth" Value="92"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="Margin" Value="8,0,0,0"/>
            <Setter Property="Foreground" Value="#FFE7E2E4"/>
            <Setter Property="Background" Value="#FF29292B"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="13,7"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder" CornerRadius="6" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#FF38383C"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="WindowCloseButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="34"/>
            <Setter Property="MinWidth" Value="34"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#FFE7E2E4"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder" CornerRadius="7" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#FFE81123"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="DangerButtonStyle" TargetType="Button">
            <Setter Property="MinWidth" Value="92"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="Padding" Value="13,7"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#FF9F2533"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                CornerRadius="6"
                                Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#FFC93646"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#FF7F1C28"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="FontComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Height" Value="36"/>
            <Setter Property="Margin" Value="0,5,0,14"/>
            <Setter Property="Foreground" Value="#FFE7E2E4"/>
            <Setter Property="Background" Value="#FF242427"/>
            <Setter Property="BorderBrush" Value="#FF3B3B40"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="MaxDropDownHeight" Value="260"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton IsChecked="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                                          Focusable="False">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border x:Name="FontBorder"
                                                Background="#FF242427"
                                                BorderBrush="#FF3B3B40"
                                                BorderThickness="1"
                                                CornerRadius="5">
                                            <Grid Margin="10,0,9,0">
                                                <ContentPresenter Content="{Binding SelectedItem, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                                                  VerticalAlignment="Center"
                                                                  TextElement.Foreground="#FFE7E2E4"/>
                                                <iconPacks:PackIconLucide Kind="ChevronDown"
                                                                          Width="14"
                                                                          Height="14"
                                                                          Foreground="#FFA9A2A5"
                                                                          HorizontalAlignment="Right"
                                                                          VerticalAlignment="Center"/>
                                            </Grid>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="FontBorder" Property="Background" Value="#FF343438"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <Popup IsOpen="{TemplateBinding IsDropDownOpen}"
                                   Placement="Bottom"
                                   AllowsTransparency="True"
                                   Focusable="False">
                                <Border MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}"
                                        Margin="0,3,0,0"
                                        Padding="4"
                                        CornerRadius="5"
                                        Background="#FF242427"
                                        BorderBrush="#FF3B3B40"
                                        BorderThickness="1">
                                    <ScrollViewer MaxHeight="260" VerticalScrollBarVisibility="Auto">
                                        <ItemsPresenter/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="ComboBoxItem">
                        <Setter Property="Height" Value="32"/>
                        <Setter Property="Padding" Value="9,0"/>
                        <Setter Property="Foreground" Value="#FFE7E2E4"/>
                        <Setter Property="Background" Value="#FF242427"/>
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ComboBoxItem">
                                    <Border x:Name="ItemBorder" CornerRadius="4" Background="{TemplateBinding Background}">
                                        <ContentPresenter Margin="{TemplateBinding Padding}" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="ItemBorder" Property="Background" Value="#FF343438"/>
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="ItemBorder" Property="Background" Value="#FF44444A"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="SettingsTabStyle" TargetType="RadioButton">
            <Setter Property="Height" Value="34"/>
            <Setter Property="Width" Value="148"/>
            <Setter Property="Margin" Value="4,0"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="#FFA9A2A5"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="TabBorder"
                                CornerRadius="6"
                                Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="TabBorder" Property="Background" Value="#FF29292D"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="TabBorder" Property="Background" Value="#FF3A3A3F"/>
                                <Setter Property="Foreground" Value="#FFF1EDEE"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="Slider">
            <Setter Property="Height" Value="18"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="IsMoveToPointEnabled" Value="True"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <Grid Height="18" VerticalAlignment="Center">
                            <Border Height="4"
                                    VerticalAlignment="Center"
                                    CornerRadius="2"
                                    Background="#FF303034"/>
                            <Track x:Name="PART_Track" VerticalAlignment="Center">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="{x:Static Slider.DecreaseLarge}">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border Height="4"
                                                        VerticalAlignment="Center"
                                                        CornerRadius="2"
                                                        Background="#FF8C727E"/>
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Width="13" Height="13">
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border x:Name="ThumbBody"
                                                        CornerRadius="7"
                                                        Background="#FFE1DADD"
                                                        BorderBrush="#FF7A6870"
                                                        BorderThickness="1"/>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="ThumbBody" Property="Background" Value="#FFFFFFFF"/>
                                                    </Trigger>
                                                    <Trigger Property="IsDragging" Value="True">
                                                        <Setter TargetName="ThumbBody" Property="Background" Value="#FFF3C9D9"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="{x:Static Slider.IncreaseLarge}">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border Background="Transparent"/>
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="PixelValueTextBoxStyle"
               TargetType="TextBox"
               BasedOn="{StaticResource {x:Type TextBox}}">
            <Setter Property="Width" Value="66"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Margin" Value="8,0,0,0"/>
            <Setter Property="Padding" Value="7,2"/>
            <Setter Property="HorizontalContentAlignment" Value="Right"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style x:Key="PanelSettingsScrollBarStyle"
               TargetType="ScrollBar"
               BasedOn="{StaticResource GlobalThinScrollBarStyle}"/>
    </Window.Resources>

    <Border BorderBrush="#FF3A3438"
            BorderThickness="1"
            CornerRadius="12"
            ClipToBounds="True">
        <Border.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#FF191719" Offset="0"/>
                <GradientStop Color="#FF141416" Offset=".5"/>
                <GradientStop Color="#FF111113" Offset="1"/>
            </LinearGradientBrush>
        </Border.Background>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="46"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                CornerRadius="11,11,0,0"
                MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                    <GradientStop Color="#FF2B2025" Offset="0"/>
                    <GradientStop Color="#FF1D1C20" Offset=".48"/>
                    <GradientStop Color="#FF171719" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <Grid Margin="16,0,7,0">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <iconPacks:PackIconLucide Kind="Settings"
                                              Width="17"
                                              Height="17"
                                              Margin="0,0,10,0"
                                              Foreground="#FFC9C2C5"/>
                    <TextBlock x:Name="SettingsWindowTitle"
                               Text="Ustawienia panelu"
                               FontSize="14"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"/>
                </StackPanel>
                    <Button Content="×"
                        Style="{StaticResource WindowCloseButtonStyle}"
                        FontSize="20"
                        HorizontalAlignment="Right"
                        Click="CloseButton_Click"/>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="26,16,26,18">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="28"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0"
              Grid.ColumnSpan="3"
              Margin="0,0,0,20">
            <Grid.RowDefinitions>
                <RowDefinition Height="34"/>
                <RowDefinition Height="11"/>
            </Grid.RowDefinitions>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <RadioButton Content="Ogólne"
                         Tag="General"
                         GroupName="SettingsTabs"
                         IsChecked="True"
                         Style="{StaticResource SettingsTabStyle}"
                         Checked="SettingsTab_Checked"/>
                <RadioButton Content="Tło"
                         Tag="Background"
                         GroupName="SettingsTabs"
                         Style="{StaticResource SettingsTabStyle}"
                         Checked="SettingsTab_Checked"/>
                <RadioButton Content="Nagłówek"
                         Tag="Header"
                         GroupName="SettingsTabs"
                         Style="{StaticResource SettingsTabStyle}"
                         Checked="SettingsTab_Checked"/>
                <RadioButton Content="Ikony"
                         Tag="Icons"
                         GroupName="SettingsTabs"
                         Style="{StaticResource SettingsTabStyle}"
                         Checked="SettingsTab_Checked"/>
            </StackPanel>
            <Border Grid.Row="1"
                    Height="1"
                    Margin="0,10,0,0"
                    Background="#FF343035"/>
        </Grid>

        <Grid Grid.Row="1" Grid.ColumnSpan="3" ClipToBounds="True">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="28"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="0"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

        <StackPanel x:Name="TitleOptionsPanel" Grid.Row="1" Grid.Column="0">
            <TextBlock Text="Tytuł" Foreground="#FFA9A2A5"/>
            <TextBox x:Name="TitleTextBox"/>
        </StackPanel>

        <StackPanel x:Name="IconOptionsPanel" Grid.Row="2" Grid.Column="0">
            <TextBlock Text="Ikonka" Foreground="#FFA9A2A5"/>
            <ComboBox x:Name="IconComboBox">
                <ComboBox.Resources>
                    <SolidColorBrush x:Key="{x:Static SystemColors.WindowBrushKey}" Color="#FF242427"/>
                    <SolidColorBrush x:Key="{x:Static SystemColors.ControlBrushKey}" Color="#FF242427"/>
                    <SolidColorBrush x:Key="{x:Static SystemColors.ControlLightBrushKey}" Color="#FF242427"/>
                    <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#FF44444A"/>
                    <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="White"/>
                </ComboBox.Resources>
                <ComboBox.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid Columns="6"/>
                    </ItemsPanelTemplate>
                </ComboBox.ItemsPanel>
                <ComboBox.ItemContainerStyle>
                    <Style TargetType="ComboBoxItem">
                        <Setter Property="Background" Value="#FF242427"/>
                        <Setter Property="Foreground" Value="White"/>
                        <Setter Property="Width" Value="46"/>
                        <Setter Property="Height" Value="42"/>
                        <Setter Property="Padding" Value="0"/>
                        <Setter Property="HorizontalContentAlignment" Value="Center"/>
                        <Setter Property="VerticalContentAlignment" Value="Center"/>
                    </Style>
                </ComboBox.ItemContainerStyle>
                <ComboBox.ItemTemplate>
                    <DataTemplate>
                        <iconPacks:PackIconLucide Kind="{Binding}"
                                                 Width="21"
                                                 Height="21"
                                                 Foreground="White"/>
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>
        </StackPanel>

        <ScrollViewer x:Name="HeaderFontTabContent"
                    Grid.Row="1"
                    Grid.RowSpan="8"
                    Grid.ColumnSpan="3"
                    HorizontalScrollBarVisibility="Disabled"
                    VerticalScrollBarVisibility="Auto"
                    Visibility="Collapsed">
            <ScrollViewer.Resources>
                <Style TargetType="ScrollBar" BasedOn="{StaticResource PanelSettingsScrollBarStyle}"/>
            </ScrollViewer.Resources>
            <StackPanel Width="520" HorizontalAlignment="Left" Margin="0,0,8,4">
            <CheckBox x:Name="HideHeaderCheckBox"
                      Content="Ukryj nagłówek"
                      Style="{StaticResource ModernCheckBoxStyle}"
                      Margin="0,0,0,16"
                      Checked="HideHeaderCheckBox_Changed"
                      Unchecked="HideHeaderCheckBox_Changed"/>

            <Border Height="1" Margin="0,0,0,16" Background="#FF343035"/>

            <StackPanel x:Name="HeaderAppearancePanel">
                <TextBlock Text="Czcionka" Foreground="#FFA9A2A5"/>
                <ComboBox x:Name="FontComboBox" Style="{StaticResource FontComboBoxStyle}">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding}" FontFamily="{Binding}"/>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>

                <Border Height="1" Margin="0,4,0,16" Background="#FF343035"/>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="24"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="Kolor tekstu" Foreground="#FFA9A2A5"/>
                        <Grid Margin="0,5,0,14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="54"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="FontColorTextBox" Height="36" Margin="0" MaxLength="7"
                                     TextChanged="FontAppearance_Changed"/>
                            <Border x:Name="FontColorPreview" Grid.Column="2" CornerRadius="5"
                                    BorderBrush="#FF4B474B" BorderThickness="1" Cursor="Hand"
                                    ToolTip="Wybierz kolor tekstu"
                                    MouseLeftButtonDown="FontColorPreview_MouseLeftButtonDown"/>
                        </Grid>
                    </StackPanel>
                    <CheckBox x:Name="BoldFontCheckBox" Grid.Column="2"
                              Content="Pogrubienie" Style="{StaticResource ModernCheckBoxStyle}"
                              VerticalAlignment="Center" Margin="0,0,0,9"
                              Checked="FontAppearance_Changed" Unchecked="FontAppearance_Changed"/>
                </Grid>

                <Grid>
                    <TextBlock Text="Odstęp między literami" Foreground="#FFA9A2A5" VerticalAlignment="Center"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <TextBox x:Name="LetterSpacingValueText" Text="0" Tag="LetterSpacingSlider"
                                 Style="{StaticResource PixelValueTextBoxStyle}"
                                 LostKeyboardFocus="PixelValueTextBox_LostKeyboardFocus"
                                 KeyDown="PixelValueTextBox_KeyDown"/>
                        <TextBlock Text="px" Margin="6,0,0,0" Foreground="#FFA9A2A5" VerticalAlignment="Center"/>
                    </StackPanel>
                </Grid>
                <Slider x:Name="LetterSpacingSlider" Minimum="-2" Maximum="8"
                        TickFrequency="0.25" Margin="0,10,0,0"
                        ValueChanged="LetterSpacingSlider_ValueChanged"/>
                <Button Content="Przywróć domyślny nagłówek" MinWidth="220"
                        Margin="0,18,0,0" HorizontalAlignment="Left"
                        Click="ResetHeaderFontDefaultsButton_Click"/>
            </StackPanel>
            </StackPanel>
        </ScrollViewer>

        <ScrollViewer x:Name="IconFontTabContent"
                    Grid.Row="1"
                    Grid.RowSpan="8"
                    Grid.ColumnSpan="3"
                    HorizontalScrollBarVisibility="Disabled"
                    VerticalScrollBarVisibility="Auto"
                    Visibility="Collapsed">
            <ScrollViewer.Resources>
                <Style TargetType="ScrollBar" BasedOn="{StaticResource PanelSettingsScrollBarStyle}"/>
            </ScrollViewer.Resources>
            <StackPanel Width="520" HorizontalAlignment="Left" Margin="0,0,8,4">
            <TextBlock Text="Czcionka" Foreground="#FFA9A2A5"/>
            <ComboBox x:Name="IconFontComboBox" Style="{StaticResource FontComboBoxStyle}">
                <ComboBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding}" FontFamily="{Binding}"/>
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>

            <Border Height="1" Margin="0,4,0,16" Background="#FF343035"/>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="24"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="Kolor tekstu" Foreground="#FFA9A2A5"/>
                    <Grid Margin="0,5,0,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="54"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="IconFontColorTextBox" Height="36" Margin="0" MaxLength="7"
                                 TextChanged="IconFontAppearance_Changed"/>
                        <Border x:Name="IconFontColorPreview" Grid.Column="2" CornerRadius="5"
                                BorderBrush="#FF4B474B" BorderThickness="1" Cursor="Hand"
                                ToolTip="Wybierz kolor podpisów ikon"
                                MouseLeftButtonDown="IconFontColorPreview_MouseLeftButtonDown"/>
                    </Grid>
                </StackPanel>
                <CheckBox x:Name="IconBoldFontCheckBox" Grid.Column="2"
                          Content="Pogrubienie" Style="{StaticResource ModernCheckBoxStyle}"
                          VerticalAlignment="Center" Margin="0,0,0,9"
                          Checked="IconFontAppearance_Changed" Unchecked="IconFontAppearance_Changed"/>
            </Grid>

            <Grid>
                <TextBlock Text="Odstęp między literami" Foreground="#FFA9A2A5" VerticalAlignment="Center"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <TextBox x:Name="IconLetterSpacingValueText" Text="0" Tag="IconLetterSpacingSlider"
                             Style="{StaticResource PixelValueTextBoxStyle}"
                             LostKeyboardFocus="PixelValueTextBox_LostKeyboardFocus"
                             KeyDown="PixelValueTextBox_KeyDown"/>
                    <TextBlock Text="px" Margin="6,0,0,0" Foreground="#FFA9A2A5" VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
            <Slider x:Name="IconLetterSpacingSlider"
                    Minimum="-2"
                    Maximum="8"
                    TickFrequency="0.25"
                    Margin="0,10,0,0"
                    ValueChanged="IconLetterSpacingSlider_ValueChanged"/>

            <Border Height="1" Margin="0,18,0,16" Background="#FF343035"/>

            <Grid>
                <TextBlock Text="Wielkość ikon" Foreground="#FFA9A2A5" VerticalAlignment="Center"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <TextBox x:Name="IconSizeValueText" Text="42" Tag="IconSizeSlider"
                             Style="{StaticResource PixelValueTextBoxStyle}"
                             LostKeyboardFocus="PixelValueTextBox_LostKeyboardFocus"
                             KeyDown="PixelValueTextBox_KeyDown"/>
                    <TextBlock Text="px" Margin="6,0,0,0" Foreground="#FFA9A2A5" VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
            <Slider x:Name="IconSizeSlider" Minimum="24" Maximum="64" TickFrequency="1"
                    Margin="0,10,0,0" ValueChanged="IconSizeSlider_ValueChanged"/>

            <Button Content="Przywróć domyślne ikony" MinWidth="210"
                    Margin="0,18,0,0" HorizontalAlignment="Left"
                    Click="ResetIconFontDefaultsButton_Click"/>
            </StackPanel>
        </ScrollViewer>

        <Grid x:Name="DimensionsPanel" Grid.Row="1" Grid.Column="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="14"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <StackPanel>
                <Grid>
                    <TextBlock Text="Szerokość" Foreground="#FFA9A2A5" VerticalAlignment="Center"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <TextBox x:Name="WidthValueText" Text="0" Tag="WidthSlider"
                                 Style="{StaticResource PixelValueTextBoxStyle}"
                                 LostKeyboardFocus="PixelValueTextBox_LostKeyboardFocus"
                                 KeyDown="PixelValueTextBox_KeyDown"/>
                        <TextBlock Text="px" Margin="6,0,0,0" Foreground="#FFA9A2A5" VerticalAlignment="Center"/>
                    </StackPanel>
                </Grid>
                <Slider x:Name="WidthSlider"
                        Minimum="310"
                        Margin="0,10,0,18"
                        ValueChanged="DimensionSlider_ValueChanged"/>
            </StackPanel>
            <StackPanel Grid.Column="2">
                <Grid>
                    <TextBlock Text="Wysokość" Foreground="#FFA9A2A5" VerticalAlignment="Center"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <TextBox x:Name="HeightValueText" Text="0" Tag="HeightSlider"
                                 Style="{StaticResource PixelValueTextBoxStyle}"
                                 LostKeyboardFocus="PixelValueTextBox_LostKeyboardFocus"
                                 KeyDown="PixelValueTextBox_KeyDown"/>
                        <TextBlock Text="px" Margin="6,0,0,0" Foreground="#FFA9A2A5" VerticalAlignment="Center"/>
                    </StackPanel>
                </Grid>
                <Slider x:Name="HeightSlider"
                        Minimum="70"
                        Margin="0,10,0,18"
                        ValueChanged="DimensionSlider_ValueChanged"/>
            </StackPanel>
        </Grid>

        <StackPanel x:Name="FolderPanel" Grid.Row="2" Grid.Column="2">
            <TextBlock Text="Folder z elementami" Foreground="#FFA9A2A5"/>
            <Grid Margin="0,5,0,14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="FolderTextBox"
                         Height="36"
                         Margin="0"
                         IsReadOnly="True"/>
                <Button Grid.Column="1"
                        Content="Wybierz"
                        Height="36"
                        Margin="8,0,0,0"
                        Click="BrowseFolderButton_Click"/>
            </Grid>
            <CheckBox x:Name="HideFoldersCheckBox"
                      Content="Ukryj foldery"
                      Style="{StaticResource ModernCheckBoxStyle}"
                      Margin="0,0,0,14"
                      Checked="HideFoldersCheckBox_Changed"
                      Unchecked="HideFoldersCheckBox_Changed"/>
        </StackPanel>

        <StackPanel x:Name="BackgroundTabContent"
                    Grid.Row="1"
                    Grid.ColumnSpan="3"
                    Width="520"
                    HorizontalAlignment="Left"
                    Margin="0,0,0,12"
                    Visibility="Collapsed">
            <TextBlock Text="Tło panelu" Foreground="#FFA9A2A5"/>
            <Grid Margin="0,5,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="14"/>
                    <ColumnDefinition Width="54"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="BackgroundColorTextBox"
                         Height="36"
                         Margin="0"
                         MaxLength="7"
                         TextChanged="BackgroundAppearance_Changed"/>
                <Border x:Name="BackgroundColorPreview"
                        Grid.Column="2"
                        CornerRadius="5"
                        BorderBrush="#FF4B474B"
                        BorderThickness="1"
                        Cursor="Hand"
                        ToolTip="Wybierz kolor"
                        MouseLeftButtonDown="BackgroundColorPreview_MouseLeftButtonDown"/>
            </Grid>

            <Border Height="1" Margin="0,14,0,16" Background="#FF343035"/>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="24"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <Grid>
                        <TextBlock Text="Zaokrąglenie" Foreground="#FFA9A2A5" VerticalAlignment="Center"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <TextBox x:Name="BorderRadiusValueText" Text="11" Tag="BorderRadiusSlider"
                                     Style="{StaticResource PixelValueTextBoxStyle}"
                                     LostKeyboardFocus="PixelValueTextBox_LostKeyboardFocus"
                                     KeyDown="PixelValueTextBox_KeyDown"/>
                            <TextBlock Text="px" Margin="6,0,0,0" Foreground="#FFA9A2A5" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Grid>
                    <Slider x:Name="BorderRadiusSlider"
                            Minimum="0"
                            Maximum="30"
                            TickFrequency="1"
                            Margin="0,10,0,14"
                            ValueChanged="BorderSlider_ValueChanged"/>
                </StackPanel>
                <StackPanel Grid.Column="2">
                    <Grid>
                        <TextBlock Text="Grubość obramowania" Foreground="#FFA9A2A5" VerticalAlignment="Center"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <TextBox x:Name="BorderThicknessValueText" Text="0" Tag="BorderThicknessSlider"
                                     Style="{StaticResource PixelValueTextBoxStyle}"
                                     LostKeyboardFocus="PixelValueTextBox_LostKeyboardFocus"
                                     KeyDown="PixelValueTextBox_KeyDown"/>
                            <TextBlock Text="px" Margin="6,0,0,0" Foreground="#FFA9A2A5" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Grid>
                    <Slider x:Name="BorderThicknessSlider"
                            Minimum="0"
                            Maximum="8"
                            TickFrequency="0.5"
                            Margin="0,10,0,14"
                            ValueChanged="BorderSlider_ValueChanged"/>
                </StackPanel>
            </Grid>

            <TextBlock Text="Kolor obramowania" Foreground="#FFA9A2A5"/>
            <Grid Margin="0,5,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="14"/>
                    <ColumnDefinition Width="54"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="BorderColorTextBox"
                         Height="36"
                         Margin="0"
                         MaxLength="7"
                         TextChanged="BorderAppearance_Changed"/>
                <Border x:Name="BorderColorPreview"
                        Grid.Column="2"
                        CornerRadius="5"
                        BorderBrush="#FF4B474B"
                        BorderThickness="1"
                        Cursor="Hand"
                        ToolTip="Wybierz kolor obramowania"
                        MouseLeftButtonDown="BorderColorPreview_MouseLeftButtonDown"/>
            </Grid>
            <Button Content="Przywróć domyślne tło"
                    MinWidth="190"
                    Margin="0,18,0,0"
                    HorizontalAlignment="Left"
                    Click="ResetBackgroundDefaultsButton_Click"/>
        </StackPanel>
        </Grid>

        <TextBlock x:Name="ValidationText"
                   Grid.Row="2"
                   Grid.ColumnSpan="3"
                   Foreground="#FFFF7777"
                   VerticalAlignment="Top"/>

        <Border Grid.Row="3"
                Grid.ColumnSpan="3"
                Height="58"
                Margin="-26,12,-26,-18"
                Padding="20,0"
                Background="#FF1C1B1E"
                BorderBrush="#FF343035"
                BorderThickness="0,1,0,0"
                CornerRadius="0,0,11,11">
            <Grid>
                <Button x:Name="DeleteButton"
                        Content="Usuń panel"
                        Style="{StaticResource DangerButtonStyle}"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center"
                        Click="DeleteButton_Click"/>
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center">
                    <Button Content="Anuluj" Click="CancelButton_Click"/>
                    <Button Content="Zapisz"
                            Background="#FF414147"
                            Click="SaveButton_Click"/>
                </StackPanel>
            </Grid>
        </Border>
        </Grid>
    </Grid>
    </Border>
</Window>
