<Window x:Class="My_Fancy_Fences.CreatorPanelSettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
        Title="Ustawienia kreatora"
        Width="340"
        Height="270"
        WindowStyle="None"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterScreen"
        Topmost="False"
        AllowsTransparency="True"
        Background="Transparent"
        Foreground="#FFE7E2E4"
        FontFamily="Segoe UI Variable Text, Segoe UI"
        FontSize="13">
    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="MinWidth" Value="82"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="Margin" Value="8,0,0,0"/>
            <Setter Property="Padding" Value="13,7"/>
            <Setter Property="Foreground" Value="#FFE7E2E4"/>
            <Setter Property="Background" Value="#FF29292B"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder" CornerRadius="6" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#FF38383C"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ModernCheckBoxStyle" TargetType="CheckBox">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Foreground" Value="#FFE7E2E4"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <StackPanel Orientation="Horizontal">
                            <Border x:Name="Box"
                                    Width="20"
                                    Height="20"
                                    CornerRadius="5"
                                    Background="#FF242427"
                                    BorderBrush="#FF3E3E43"
                                    BorderThickness="1">
                                <Path x:Name="Mark"
                                      Width="10"
                                      Height="7"
                                      Data="M 0 3 L 3.5 6.5 L 10 0"
                                      Stroke="White"
                                      StrokeThickness="2"
                                      Visibility="Collapsed"/>
                            </Border>
                            <ContentPresenter Margin="10,0,0,0"
                                              VerticalAlignment="Center"
                                              TextElement.Foreground="#FFE7E2E4"/>
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Box" Property="BorderBrush" Value="#FF65656C"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Box" Property="Background" Value="#FF46464C"/>
                                <Setter TargetName="Box" Property="BorderBrush" Value="#FF58585F"/>
                                <Setter TargetName="Mark" Property="Visibility" Value="Visible"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="WindowCloseButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="34"/>
            <Setter Property="MinWidth" Value="34"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#FFE7E2E4"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder" CornerRadius="7" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#FFE81123"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border BorderBrush="#FF3A3438"
            BorderThickness="1"
            CornerRadius="12"
            ClipToBounds="True">
        <Border.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#FF191719" Offset="0"/>
                <GradientStop Color="#FF141416" Offset=".5"/>
                <GradientStop Color="#FF111113" Offset="1"/>
            </LinearGradientBrush>
        </Border.Background>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="46"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border CornerRadius="11,11,0,0" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#FF2B2025" Offset="0"/>
                        <GradientStop Color="#FF1D1C20" Offset=".48"/>
                        <GradientStop Color="#FF171719" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <Grid Margin="16,0,7,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <iconPacks:PackIconLucide Kind="Settings"
                                                  Width="17"
                                                  Height="17"
                                                  Margin="0,0,10,0"
                                                  Foreground="#FFC9C2C5"/>
                        <TextBlock Text="Ustawienia kreatora"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                    <Button Content="×"
                            Style="{StaticResource WindowCloseButtonStyle}"
                            HorizontalAlignment="Right"
                            FontSize="20"
                            Click="CancelButton_Click"/>
                </Grid>
            </Border>

            <Grid Grid.Row="1" Margin="22,18">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <CheckBox x:Name="HideHeaderCheckBox"
                          Content="Ukryj nagłówek"
                          Style="{StaticResource ModernCheckBoxStyle}"
                          Checked="Option_Changed"
                          Unchecked="Option_Changed"/>

                <StackPanel Grid.Row="1" Margin="0,20,0,0">
                    <TextBlock Text="Tło panelu" Foreground="#FFA9A2A5" FontSize="11" FontWeight="SemiBold"/>
                    <Grid Margin="0,8,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="54"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="BackgroundColorTextBox"
                                 Height="34"
                                 Padding="9,5"
                                 Foreground="#FFE7E2E4"
                                 Background="#FF242427"
                                 BorderBrush="#FF3B3B40"
                                 BorderThickness="1"
                                 IsReadOnly="True"/>
                        <Border x:Name="BackgroundColorPreview"
                                Grid.Column="1"
                                Margin="8,0,0,0"
                                CornerRadius="5"
                                BorderBrush="#FF4B474B"
                                BorderThickness="1"
                                Cursor="Hand"
                                MouseLeftButtonDown="BackgroundColorPreview_MouseLeftButtonDown"/>
                    </Grid>
                </StackPanel>

                <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Anuluj" Click="CancelButton_Click"/>
                    <Button Content="Zapisz" Background="#FF414147" Click="SaveButton_Click"/>
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</Window>
