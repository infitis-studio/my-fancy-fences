<Window x:Class="My_Fancy_Fences.PanelsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
        Title="Ustawienia"
        Width="670"
        Height="540"
        MinWidth="480"
        MinHeight="360"
        WindowStyle="None"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterScreen"
        Topmost="False"
        ShowInTaskbar="True"
        AllowsTransparency="True"
        Background="Transparent"
        Foreground="#FFE7E2E4"
        FontFamily="Segoe UI Variable Text, Segoe UI"
        FontSize="13">
    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="MinWidth" Value="82"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="Padding" Value="13,7"/>
            <Setter Property="Foreground" Value="#FFE7E2E4"/>
            <Setter Property="Background" Value="#FF29292B"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder" CornerRadius="6" Background="{TemplateBinding Background}">
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#FF38383C"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="WindowCloseButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="34"/>
            <Setter Property="MinWidth" Value="34"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#FFE7E2E4"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder" CornerRadius="7" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#FFE81123"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="StatusToggleButtonStyle" TargetType="Button">
            <Setter Property="MinWidth" Value="0"/>
            <Setter Property="Height" Value="24"/>
            <Setter Property="Padding" Value="14,4,11,4"/>
            <Setter Property="Foreground" Value="#FFE4F0EA"/>
            <Setter Property="Background" Value="#FF3B5149"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="StatusBorder" CornerRadius="9" Background="{TemplateBinding Background}">
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="StatusBorder" Property="Background" Value="#FF4A655A"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="Content" Value="Ukryty">
                                <Setter TargetName="StatusBorder" Property="Background" Value="#FF584247"/>
                                <Setter Property="Foreground" Value="#FFF0E2E5"/>
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="Content" Value="Ukryty"/>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="StatusBorder" Property="Background" Value="#FF6A5056"/>
                                <Setter Property="Foreground" Value="White"/>
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CompactCheckBoxStyle" TargetType="CheckBox">
            <Setter Property="Foreground" Value="#FFBDB6B9"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <StackPanel Orientation="Horizontal">
                            <Border x:Name="Box" Width="16" Height="16" CornerRadius="4"
                                    Background="#FF252529" BorderBrush="#FF444449" BorderThickness="1">
                                <Path x:Name="Mark" Width="8" Height="6"
                                      Data="M 0 2.5 L 3 5.5 L 8 0" Stroke="White"
                                      StrokeThickness="1.7" Visibility="Collapsed"/>
                            </Border>
                            <ContentPresenter Margin="7,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Box" Property="BorderBrush" Value="#FF77717A"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Box" Property="Background" Value="#FF62505A"/>
                                <Setter TargetName="Mark" Property="Visibility" Value="Visible"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SettingsTabStyle" TargetType="RadioButton">
            <Setter Property="Height" Value="34"/>
            <Setter Property="Width" Value="145"/>
            <Setter Property="Margin" Value="4,0"/>
            <Setter Property="Foreground" Value="#FFA9A2A5"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="TabBorder" CornerRadius="6" Background="Transparent">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="TabBorder" Property="Background" Value="#FF29292D"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="TabBorder" Property="Background" Value="#FF3A3A3F"/>
                                <Setter Property="Foreground" Value="#FFF1EDEE"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="LanguageComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Height" Value="34"/>
            <Setter Property="Foreground" Value="#FFE7E2E4"/>
            <Setter Property="Background" Value="#FF242427"/>
            <Setter Property="BorderBrush" Value="#FF3B3B40"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="MaxDropDownHeight" Value="260"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton IsChecked="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                                          Focusable="False">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border x:Name="ComboSurface" Background="#FF242427"
                                                BorderBrush="#FF3B3B40" BorderThickness="1" CornerRadius="6">
                                            <Grid Margin="10,0,9,0">
                                                <TextBlock Text="{Binding SelectedItem.Name, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                                           Foreground="#FFE7E2E4" VerticalAlignment="Center"/>
                                                <iconPacks:PackIconLucide Kind="ChevronDown" Width="14" Height="14"
                                                                          Foreground="#FFA9A2A5"
                                                                          HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                            </Grid>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="ComboSurface" Property="Background" Value="#FF303034"/>
                                                <Setter TargetName="ComboSurface" Property="BorderBrush" Value="#FF4A4A50"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <Popup IsOpen="{TemplateBinding IsDropDownOpen}" Placement="Bottom"
                                   AllowsTransparency="True" Focusable="False">
                                <Border MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}"
                                        Margin="0,4,0,0" Padding="4" CornerRadius="6"
                                        Background="#FF202024" BorderBrush="#FF3B3B40" BorderThickness="1">
                                    <ScrollViewer MaxHeight="260" VerticalScrollBarVisibility="Auto">
                                        <ItemsPresenter/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="ComboBoxItem">
                        <Setter Property="Height" Value="32"/>
                        <Setter Property="Padding" Value="10,0"/>
                        <Setter Property="Foreground" Value="#FFE7E2E4"/>
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ComboBoxItem">
                                    <Border x:Name="ItemSurface" CornerRadius="4" Background="{TemplateBinding Background}">
                                        <ContentPresenter Margin="{TemplateBinding Padding}" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="ItemSurface" Property="Background" Value="#FF303034"/>
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="ItemSurface" Property="Background" Value="#FF3A3A40"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="UpdateActionButtonStyle" TargetType="Button">
            <Setter Property="MinWidth" Value="126"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="Foreground" Value="#FFE4E0E2"/>
            <Setter Property="Background" Value="#FF2A2B30"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Surface" Background="{TemplateBinding Background}"
                                BorderBrush="#FF3A3B42" BorderThickness="1" CornerRadius="6">
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Surface" Property="Background" Value="#FF36383E"/>
                                <Setter TargetName="Surface" Property="BorderBrush" Value="#FF4A4C54"/>
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="Tag" Value="Release"/>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="Surface" Property="Background" Value="#FF345B47"/>
                                <Setter TargetName="Surface" Property="BorderBrush" Value="#FF48785E"/>
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="UpdateReleaseButtonStyle" TargetType="Button" BasedOn="{StaticResource UpdateActionButtonStyle}">
            <Setter Property="Tag" Value="Release"/>
            <Setter Property="Foreground" Value="#FFD9F4E4"/>
            <Setter Property="Background" Value="#FF294638"/>
        </Style>

    </Window.Resources>

    <Border BorderBrush="#FF3A3438" BorderThickness="1" CornerRadius="12" ClipToBounds="True">
        <Border.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#FF191719" Offset="0"/>
                <GradientStop Color="#FF141416" Offset=".5"/>
                <GradientStop Color="#FF111113" Offset="1"/>
            </LinearGradientBrush>
        </Border.Background>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="46"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="58"/>
            </Grid.RowDefinitions>

            <Border CornerRadius="11,11,0,0" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#FF2B2025" Offset="0"/>
                        <GradientStop Color="#FF1D1C20" Offset=".48"/>
                        <GradientStop Color="#FF171719" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <Grid Margin="16,0,7,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <iconPacks:PackIconLucide Kind="Settings" Width="17" Height="17"
                                                  Margin="0,0,10,0" Foreground="#FFC9C2C5"/>
                        <TextBlock Text="Ustawienia" FontSize="14" FontWeight="SemiBold"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                    <Button Content="×" Style="{StaticResource WindowCloseButtonStyle}"
                            HorizontalAlignment="Right" FontSize="20" Click="CloseButton_Click"/>
                </Grid>
            </Border>

            <Grid Grid.Row="1" Margin="22,16,18,12">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Grid Margin="0,0,0,15">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="34"/>
                        <RowDefinition Height="11"/>
                    </Grid.RowDefinitions>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <RadioButton Content="Ogólne" Tag="General" IsChecked="True"
                                     GroupName="SettingsTabs" Style="{StaticResource SettingsTabStyle}"
                                     Checked="SettingsTab_Checked"/>
                        <RadioButton Content="Panele" Tag="Panels"
                                     GroupName="SettingsTabs" Style="{StaticResource SettingsTabStyle}"
                                     Checked="SettingsTab_Checked"/>
                        <RadioButton Content="Import / eksport" Tag="ImportExport"
                                     GroupName="SettingsTabs" Style="{StaticResource SettingsTabStyle}"
                                     Checked="SettingsTab_Checked"/>
                        <RadioButton x:Name="UpdatesTabButton" Content="Aktualizacja" Tag="Updates"
                                     GroupName="SettingsTabs" Style="{StaticResource SettingsTabStyle}"
                                     Checked="SettingsTab_Checked"/>
                    </StackPanel>
                    <Border Grid.Row="1" Height="1" Margin="0,10,0,0" Background="#FF343035"/>
                </Grid>

                <Grid Grid.Row="1">
                    <Grid x:Name="GeneralTabContent" Margin="4,4,4,0">
                        <StackPanel>
                            <TextBlock Text="Ogólne" FontSize="18" FontWeight="SemiBold"/>
                            <TextBlock Text="Podstawowe narzędzia aplikacji"
                                       Margin="0,4,0,18" Foreground="#FFA9A2A5" FontSize="11"/>
                            <Border Padding="16" CornerRadius="8" Background="#FF1E1E21"
                                    BorderBrush="#FF303035" BorderThickness="1">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="38"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <iconPacks:PackIconLucide Kind="RefreshCw" Width="20" Height="20"
                                                              Foreground="#FFCFC7CA" VerticalAlignment="Top"/>
                                    <StackPanel Grid.Column="1" Margin="0,0,18,0">
                                        <TextBlock Text="Odśwież ikony" FontWeight="SemiBold"/>
                                        <TextBlock Margin="0,6,0,0" Foreground="#FFA9A2A5" FontSize="11"
                                                   TextWrapping="Wrap"
                                                   Text="Ponownie pobiera ikony skrótów we wszystkich panelach."/>
                                    </StackPanel>
                                    <Button Grid.Column="2" Content="Odśwież ikony"
                                            VerticalAlignment="Center"
                                            Click="RefreshIconsButton_Click"/>
                                </Grid>
                            </Border>
                            <Border Margin="0,10,0,0" Padding="16" CornerRadius="8"
                                    Background="#FF1E1E21" BorderBrush="#FF303035" BorderThickness="1">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="38"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <iconPacks:PackIconLucide Kind="MousePointerClick" Width="20" Height="20"
                                                              Foreground="#FFCFC7CA" VerticalAlignment="Top"/>
                                    <StackPanel Grid.Column="1" Margin="0,0,18,0">
                                        <TextBlock Text="Uruchamianie elementów" FontWeight="SemiBold"/>
                                        <TextBlock Margin="0,6,0,0" Foreground="#FFA9A2A5" FontSize="11"
                                                   TextWrapping="Wrap"
                                                   Text="Domyślnie ikony uruchamiają się pojedynczym kliknięciem."/>
                                    </StackPanel>
                                    <CheckBox x:Name="DoubleClickActivationCheckBox"
                                              Grid.Column="2"
                                              Content="Uruchamiaj dwuklikiem"
                                              Style="{StaticResource CompactCheckBoxStyle}"
                                              VerticalAlignment="Center"
                                              Checked="DoubleClickActivationCheckBox_Changed"
                                              Unchecked="DoubleClickActivationCheckBox_Changed"/>
                                </Grid>
                            </Border>
                            <Border Margin="0,10,0,0" Padding="16" CornerRadius="8"
                                    Background="#FF1E1E21" BorderBrush="#FF303035" BorderThickness="1">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="38"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <iconPacks:PackIconLucide Kind="Languages" Width="20" Height="20"
                                                              Foreground="#FFCFC7CA" VerticalAlignment="Top"/>
                                    <StackPanel Grid.Column="1" Margin="0,0,18,0">
                                        <TextBlock Text="Język" FontWeight="SemiBold"/>
                                        <TextBlock Text="Język interfejsu" Margin="0,6,0,0"
                                                   Foreground="#FFA9A2A5" FontSize="11"/>
                                    </StackPanel>
                                    <ComboBox x:Name="LanguageComboBox" Grid.Column="2"
                                              Width="170" Style="{StaticResource LanguageComboBoxStyle}"
                                              DisplayMemberPath="Name" SelectedValuePath="Code"
                                              SelectionChanged="LanguageComboBox_SelectionChanged"/>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </Grid>

                    <Grid x:Name="PanelsTabContent" Visibility="Collapsed">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Grid Margin="4,4,4,14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="Panele" FontSize="18" FontWeight="SemiBold"/>
                                <TextBlock Text="Wszystkie panele utworzone w aplikacji"
                                           Margin="0,4,0,0" Foreground="#FFA9A2A5" FontSize="11"/>
                            </StackPanel>
                            <Border Grid.Column="1" Padding="10,5" CornerRadius="10"
                                    Background="#FF29292D" VerticalAlignment="Center">
                                <TextBlock x:Name="PanelCountText" Foreground="#FFCFC7CA" FontSize="11"/>
                            </Border>
                        </Grid>
                        <Border Grid.Row="1" Height="1" Margin="4,0,4,14" Background="#FF343035"/>
                        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled">
                            <ItemsControl x:Name="PanelsItemsControl">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="4,0,8,10" Padding="14,12" CornerRadius="8"
                                        Background="#FF1E1E21" BorderBrush="#FF303035" BorderThickness="1">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="42"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <Border Width="34" Height="34" CornerRadius="8"
                                                Background="#FF2B2B2F" VerticalAlignment="Top">
                                            <iconPacks:PackIconLucide Kind="{Binding Icon}" Width="18" Height="18"
                                                                      Foreground="#FFD8D1D4"
                                                                      HorizontalAlignment="Center"
                                                                      VerticalAlignment="Center"/>
                                        </Border>
                                        <StackPanel Grid.Column="1" Margin="10,0,14,0">
                                            <TextBlock Text="{Binding Title}" FontWeight="SemiBold" FontSize="13"
                                                       TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Text="{Binding FolderPath}" Margin="0,5,0,0"
                                                       Foreground="#FFA9A2A5" FontSize="10.5"
                                                       TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Text="{Binding Details}" Margin="0,5,0,0"
                                                       Foreground="#FF777177" FontSize="10.5"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="2" Margin="0,0,4,0"
                                                    VerticalAlignment="Top" HorizontalAlignment="Right">
                                            <Button Content="{Binding Status}"
                                                    Tag="{Binding PanelKey}"
                                                    Style="{StaticResource StatusToggleButtonStyle}"
                                                    HorizontalAlignment="Center"
                                                    Click="PanelVisibilityButton_Click"/>
                                            <Button Content="Edytuj"
                                                    Tag="{Binding PanelKey}"
                                                    MinWidth="0" Height="20" Padding="10,2"
                                                    Margin="0,10,0,0" FontSize="9.5"
                                                    Background="#FF29292D"
                                                    HorizontalAlignment="Center"
                                                    Visibility="{Binding EditVisibility}"
                                                    Click="EditPanelButton_Click"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>

                    <StackPanel x:Name="ImportExportTabContent" Margin="4,4,4,0" Visibility="Collapsed">
                        <TextBlock Text="Import / eksport" FontSize="18" FontWeight="SemiBold"/>
                        <TextBlock Text="Przenoszenie konfiguracji aplikacji i paneli"
                                   Margin="0,4,0,18" Foreground="#FFA9A2A5" FontSize="11"/>
                        <Border Padding="16" CornerRadius="8" Background="#FF1E1E21"
                                BorderBrush="#FF303035" BorderThickness="1">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="34"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <iconPacks:PackIconLucide Kind="Archive" Width="20" Height="20"
                                                          Foreground="#FFCFC7CA" VerticalAlignment="Top"/>
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="Kopia konfiguracji" FontWeight="SemiBold"/>
                                    <TextBlock Margin="0,6,0,0" Foreground="#FFA9A2A5" FontSize="11"
                                               TextWrapping="Wrap"
                                               Text="Tutaj będzie można eksportować ustawienia do pliku oraz importować je na innym komputerze."/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </StackPanel>

                    <Grid x:Name="UpdatesTabContent" Margin="4,4,4,0" Visibility="Collapsed">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <StackPanel>
                            <TextBlock Text="Aktualizacja" FontSize="18" FontWeight="SemiBold"/>
                            <TextBlock Text="Sprawdź dostępność nowej wersji na GitHubie"
                                       Margin="0,4,0,18" Foreground="#FFA9A2A5" FontSize="11"/>
                        </StackPanel>

                        <Border x:Name="UpdateStatusCard" Grid.Row="1" Padding="16" CornerRadius="8"
                                Background="#FF1E1E21" BorderBrush="#FF303035" BorderThickness="1">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="38"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <iconPacks:PackIconLucide x:Name="UpdateStatusIcon"
                                                          Kind="RefreshCw" Width="20" Height="20"
                                                          Foreground="#FFCFC7CA" VerticalAlignment="Top"/>

                                <StackPanel Grid.Column="1" Margin="0,0,18,0">
                                    <TextBlock x:Name="UpdateStatusText"
                                               Text="Otwórz zakładkę, aby sprawdzić aktualizacje"
                                               FontWeight="SemiBold"/>
                                    <TextBlock Margin="0,7,0,0" Foreground="#FFA9A2A5" FontSize="11">
                                        <Run Text="Zainstalowana wersja: "/>
                                        <Run x:Name="CurrentVersionText" Text="v0.1.0"/>
                                    </TextBlock>
                                    <TextBlock Margin="0,4,0,0" Foreground="#FFA9A2A5" FontSize="11">
                                        <Run Text="Najnowsza wersja: "/>
                                        <Run x:Name="LatestVersionText" Text="—"/>
                                    </TextBlock>
                                    <Button x:Name="LatestReleaseLinkButton"
                                            Width="58" MinWidth="0" Height="23"
                                            Margin="0,8,0,0" Padding="7,0"
                                            HorizontalAlignment="Left"
                                            Background="#FF254333"
                                            Foreground="#FFBFE8CF"
                                            Visibility="Collapsed"
                                            Click="LatestReleaseLinkButton_Click">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="LinkSurface" Background="{TemplateBinding Background}"
                                                        CornerRadius="5">
                                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                                        <iconPacks:PackIconLucide Kind="ExternalLink" Width="11" Height="11"
                                                                                  Margin="0,0,5,0" VerticalAlignment="Center"/>
                                                        <TextBlock Text="Link" FontSize="10" FontWeight="SemiBold"
                                                                   VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="LinkSurface" Property="Background" Value="#FF315942"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                </StackPanel>

                                <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                    <Button x:Name="CheckUpdatesButton"
                                            Style="{StaticResource UpdateActionButtonStyle}"
                                            Click="CheckUpdatesButton_Click">
                                        <StackPanel Orientation="Horizontal">
                                            <iconPacks:PackIconLucide Kind="RefreshCw" Width="15" Height="15"
                                                                      Margin="0,0,8,0" VerticalAlignment="Center"/>
                                            <TextBlock Text="Sprawdź ponownie" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>
                                    <Button x:Name="OpenReleaseButton"
                                            Margin="0,8,0,0"
                                            Style="{StaticResource UpdateReleaseButtonStyle}"
                                            Visibility="Collapsed"
                                            Click="OpenReleaseButton_Click">
                                        <StackPanel Orientation="Horizontal">
                                            <iconPacks:PackIconLucide Kind="Download" Width="15" Height="15"
                                                                      Margin="0,0,8,0" VerticalAlignment="Center"/>
                                            <TextBlock Text="Aktualizuj" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>
            </Grid>

            <Border Grid.Row="2" Background="#FF1C1B1E" BorderBrush="#FF343035"
                    BorderThickness="0,1,0,0" Padding="8,0,12,0" CornerRadius="0,0,11,11">
                <Grid>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center">
                        <Button Width="160" MinWidth="0" Height="34" Padding="0"
                                Background="Transparent" Click="FooterKoFiButton_Click">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="KoFiButtonSurface"
                                            Width="140" Height="34"
                                            Padding="8,0,12,0"
                                            Background="#FF6698E3"
                                            CornerRadius="8"
                                            ClipToBounds="True">
                                        <Image Source="/Assets/ko-fi-footer.png"
                                               Stretch="Uniform"
                                               RenderOptions.BitmapScalingMode="HighQuality"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="KoFiButtonSurface" Property="Opacity" Value="0.88"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <Button x:Name="FooterUpdateButton"
                                Width="112" MinWidth="0" Height="34" Margin="8,0,0,0" Padding="8,0"
                                Background="#FF24252A" Click="FooterUpdateButton_Click">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="FooterUpdateSurface"
                                            Background="{TemplateBinding Background}"
                                            CornerRadius="6">
                                        <ContentPresenter Margin="{TemplateBinding Padding}"
                                                          HorizontalAlignment="Center"
                                                          VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="FooterUpdateSurface"
                                                    Property="Background" Value="#FF34353A"/>
                                        </Trigger>
                                        <MultiTrigger>
                                            <MultiTrigger.Conditions>
                                                <Condition Property="Tag" Value="UpdateAvailable"/>
                                                <Condition Property="IsMouseOver" Value="True"/>
                                            </MultiTrigger.Conditions>
                                            <Setter TargetName="FooterUpdateSurface"
                                                    Property="Background" Value="#FF2F8055"/>
                                        </MultiTrigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <iconPacks:PackIconLucide x:Name="FooterUpdateBellIcon"
                                                          Kind="Bell" Width="16" Height="16"
                                                          Margin="0,0,7,0" Foreground="#FFE8F7EE"
                                                          Opacity="0.84" Visibility="Collapsed"/>
                                <TextBlock x:Name="FooterUpdateText" Text="Aktualizacja"
                                           Foreground="#FFD7D1D4" FontSize="10.5"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                    <Button Content="Zamknij" HorizontalAlignment="Right" VerticalAlignment="Center"
                            Click="CloseButton_Click"/>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
