<Window x:Class="My_Fancy_Fences.WallpaperDetailsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
        Title="Szczegóły tapety"
        Width="920"
        Height="600"
        MinWidth="760"
        MinHeight="480"
        WindowStyle="None"
        WindowStartupLocation="Manual"
        ResizeMode="CanResize"
        AllowsTransparency="True"
        Background="Transparent"
        Foreground="White"
        Topmost="False">
    <Window.Resources>
        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="36"/>
            <Setter Property="MinWidth" Value="96"/>
            <Setter Property="Padding" Value="18,0"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#FF2B3039"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Border"
                                CornerRadius="7"
                                Background="{TemplateBinding Background}">
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#FF39404B"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#FF242932"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Border" Property="Opacity" Value=".45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource ActionButtonStyle}">
            <Setter Property="Background" Value="#FF3E8E82"/>
        </Style>

        <Style x:Key="WindowCaptionButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="36"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="#FFDDE2EA"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                CornerRadius="7"
                                Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#22FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="WindowCloseButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource WindowCaptionButtonStyle}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                CornerRadius="7"
                                Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#FFE81123"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ScrollBar">
            <Setter Property="Width" Value="4"/>
            <Setter Property="MinWidth" Value="4"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid Background="Transparent">
                            <Track x:Name="PART_Track" IsDirectionReversed="True">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageUpCommand" Opacity="0"/>
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border Margin="0,2"
                                                        CornerRadius="2"
                                                        Background="#35FFFFFF"/>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageDownCommand" Opacity="0"/>
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border x:Name="OuterWindowBorder"
            BorderBrush="#FF343A45"
            BorderThickness="1"
            CornerRadius="13"
            ClipToBounds="True">
        <Border.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#F522252C" Offset="0"/>
                <GradientStop Color="#F215181E" Offset=".5"/>
                <GradientStop Color="#F20F1217" Offset="1"/>
            </LinearGradientBrush>
        </Border.Background>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="46"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="58"/>
            </Grid.RowDefinitions>

            <Border x:Name="TitleBarBorder"
                    CornerRadius="12,12,0,0"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#F02A1F27" Offset="0"/>
                        <GradientStop Color="#EC1C2027" Offset=".38"/>
                        <GradientStop Color="#F0181B21" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <Grid Margin="16,0,7,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <iconPacks:PackIconLucide Kind="Image"
                                                  Width="18"
                                                  Height="18"
                                                  Margin="0,0,10,0"
                                                  Foreground="#FFB9C1CC"/>
                        <TextBlock Text="Szczegóły tapety"
                                   FontSize="14"
                                   FontWeight="SemiBold"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center">
                        <Button Style="{StaticResource WindowCaptionButtonStyle}"
                                ToolTip="Minimalizuj"
                                Click="MinimizeButton_Click">
                            <iconPacks:PackIconLucide Kind="Minus" Width="16" Height="16"/>
                        </Button>
                        <Button Style="{StaticResource WindowCaptionButtonStyle}"
                                ToolTip="Pełny ekran"
                                Click="MaximizeButton_Click">
                            <iconPacks:PackIconLucide x:Name="MaximizeIcon"
                                                      Kind="Square"
                                                      Width="14"
                                                      Height="14"/>
                        </Button>
                        <Button Content="×"
                                Style="{StaticResource WindowCloseButtonStyle}"
                                FontSize="20"
                                Click="CloseButton_Click"/>
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Grid.Row="1" Margin="14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="280"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border BorderBrush="#FF292E37"
                        BorderThickness="1"
                        CornerRadius="10"
                        Padding="14">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#D42B202A" Offset="0"/>
                            <GradientStop Color="#B71B1F26" Offset=".55"/>
                            <GradientStop Color="#9E12161D" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <TextBlock Text="Properties"
                                       Foreground="#FF7F8996"
                                       FontSize="10"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,10"/>

                            <ItemsControl x:Name="PropertiesItemsControl">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,0,0,9">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="94"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="{Binding Name}"
                                                       Foreground="#FF8F99A6"
                                                       FontSize="11"/>
                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding Value}"
                                                       Foreground="#FFE7EBF0"
                                                       FontSize="11"
                                                       TextWrapping="Wrap"/>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <Border Height="1" Margin="0,9,0,13" Background="#FF303640"/>

                            <TextBlock Text="Tagi"
                                       Foreground="#FF7F8996"
                                       FontSize="10"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,8"/>

                            <TextBlock x:Name="TagsLoadingText"
                                       Text="Ładowanie tagów..."
                                       Foreground="#FF8F99A6"
                                       FontSize="11"/>

                            <ItemsControl x:Name="TagsItemsControl">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="0,0,6,6"
                                                Padding="8,4"
                                                CornerRadius="5"
                                                Background="#FF2B3039">
                                            <TextBlock Text="{Binding}"
                                                       Foreground="#FFE7EBF0"
                                                       FontSize="11"/>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </ScrollViewer>
                </Border>

                <Border Grid.Column="1"
                        Margin="12,0,0,0"
                        Background="#FF101318"
                        BorderBrush="#FF292E37"
                        BorderThickness="1"
                        CornerRadius="10"
                        ClipToBounds="True">
                    <Grid>
                        <Image x:Name="WallpaperPreviewImage"
                               Stretch="Uniform"
                               RenderOptions.BitmapScalingMode="HighQuality"/>
                        <Border x:Name="LoadingOverlay"
                                Width="112"
                                Height="112"
                                CornerRadius="12"
                                Background="#E622262E"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center">
                            <StackPanel HorizontalAlignment="Center"
                                        VerticalAlignment="Center">
                                <Grid Width="34" Height="34" HorizontalAlignment="Center">
                                    <Ellipse Stroke="#3AFFFFFF" StrokeThickness="3"/>
                                    <Ellipse Stroke="#FF63B8AA"
                                             StrokeThickness="3"
                                             StrokeDashArray="2,6"
                                             StrokeStartLineCap="Round">
                                        <Ellipse.RenderTransform>
                                            <RotateTransform x:Name="LoadingRotateTransform"
                                                             CenterX="17"
                                                             CenterY="17"/>
                                        </Ellipse.RenderTransform>
                                    </Ellipse>
                                </Grid>
                                <TextBlock Text="Ładowanie"
                                           Margin="0,12,0,0"
                                           Foreground="#FFD8DDE5"
                                           FontSize="11"
                                           TextAlignment="Center"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>
            </Grid>

            <Border x:Name="FooterBorder"
                    Grid.Row="2"
                    CornerRadius="0,0,12,12"
                    BorderBrush="#FF292E37"
                    BorderThickness="0,1,0,0">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#EA1E222A" Offset="0"/>
                        <GradientStop Color="#F0181C22" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <Grid Margin="14,0">
                    <TextBlock x:Name="StatusText"
                               Foreground="#FF9CA5B1"
                               VerticalAlignment="Center"
                               FontSize="11"/>
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center"
                                Margin="0,0,28,0">
                        <Button Content="Pobierz"
                                Style="{StaticResource ActionButtonStyle}"
                                Margin="0,0,8,0"
                                Click="DownloadButton_Click"/>
                        <Button Content="Ustaw jako tapeta"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Click="SetWallpaperButton_Click"/>
                    </StackPanel>
                </Grid>
            </Border>
            <Border x:Name="ResizeGrip"
                    Width="26"
                    Height="26"
                    Grid.RowSpan="3"
                    Panel.ZIndex="20"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Bottom"
                    Background="Transparent"
                    Cursor="SizeNWSE"
                    MouseLeftButtonDown="ResizeGrip_MouseLeftButtonDown"
                    MouseLeftButtonUp="ResizeGrip_MouseLeftButtonUp"
                    MouseMove="ResizeGrip_MouseMove">
                <Canvas Width="16"
                        Height="16"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Bottom"
                        Margin="0,0,5,5"
                        Opacity=".48">
                    <Path Data="M 15 6 L 6 15"
                          Stroke="White"
                          StrokeThickness="1.4"
                          StrokeStartLineCap="Round"
                          StrokeEndLineCap="Round"/>
                    <Path Data="M 15 11 L 11 15"
                          Stroke="White"
                          StrokeThickness="1.4"
                          StrokeStartLineCap="Round"
                          StrokeEndLineCap="Round"/>
                </Canvas>
            </Border>
        </Grid>
    </Border>
</Window>
